---
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Heading from '../ui/Heading.astro';
import { getCaseStudyUrl } from '../../data/caseStudies';
import { withBase } from '../../utils/paths';

const { showTitle = true } = Astro.props;

const workImageItems = [
  {
    image: withBase('/images/work/Mockup_UMGT_Website.png'),
    alt: 'Ursa Major Global Tech brand and website mockup',
    href: getCaseStudyUrl('ursa-major-global-tech'),
  },
  {
    image: withBase('/images/work/Mockup_Design_Guide_UMGT.webp'),
    alt: 'Ursa Major Global Tech design guide mockup',
    href: getCaseStudyUrl('ursa-major-global-tech'),
  },
  {
    image: withBase('/images/work/Bravo-Mockup.webp'),
    alt: 'Bravo Farms website mockup shown on desktop and tablet devices',
    href: getCaseStudyUrl('bravo-farms'),
  },
  {
    image: withBase('/images/work/distinct-homepage-mockup.webp'),
    alt: 'Distinct Creative Group website mockup displayed on a tablet',
    href: getCaseStudyUrl('distinct-creative-group'),
  },
  {
    image: withBase('/images/work/dc-marketing.webp'),
    alt: 'High quality mickup of clean modern logo design for marketing firm',
    href: getCaseStudyUrl('dc-marketing'),
  },
  {
    image: withBase('/images/work/gasco-mockup.png'),
    alt: 'Gasco website mockup displayed across multiple devices',
  },
 {
    image: withBase('/images/work/POLYCHROME-BRAND-MOCKUP-CONCEPT-1.png'),
    alt: 'BRand and ,logo design for Polychrome Donuts',
  },
  {
    image: withBase('/images/work/design-studio.webp'),
    alt: 'University website design Spring Arbor, through Modern Campus',
  },
];

const workVideoItems = [
  {
    src: 'https://res.cloudinary.com/dgqpeqpsf/video/upload/v1780506862/SocialMediaClip8x10_td9qsv.mp4',
    label: 'Social media showreel clip',
  },
  {
    src: 'https://res.cloudinary.com/dgqpeqpsf/video/upload/v1780506768/distinct_showreel_v7shqm.mp4',
    label: 'Distinct Creative Group showreel clip',
    href: getCaseStudyUrl('distinct-creative-group'),
  },
  {
    src: 'https://res.cloudinary.com/dgqpeqpsf/video/upload/v1780506765/bravo_reel_1_ncmrvg.mp4',
    label: 'Bravo Farms showreel clip',
    href: getCaseStudyUrl('bravo-farms'),
  },
];

const marqueeRows = [
  {
    items: workImageItems,
    mediaType: 'image',
    reverse: false,
    ariaLabel: 'Selected work previews',
  },
  {
    items: workVideoItems,
    mediaType: 'video',
    reverse: true,
    ariaLabel: 'Selected work videos',
  },
];
---

<Section class="work" tone="dark">
  {showTitle && (
    <Container>
      <Heading tone="dark">Work</Heading>
    </Container>
  )}

  <div class="work__rows">
    {marqueeRows.map((row) => (
      <div
        class:list={[
          'work__marquee',
          row.reverse && 'work__marquee--reverse',
        ]}
        aria-label={row.ariaLabel}
      >
        <div
          class:list={[
            'work__track',
            row.reverse && 'work__track--reverse',
          ]}
        >
          <div class="work__group">
            {row.items.map((item) => (
              row.mediaType === 'image' ? (
                item.href ? (
                  <a href={item.href} class="work__item">
                    <img
                      src={item.image}
                      alt={item.alt}
                      class="work__image"
                      loading="lazy"
                    />
                  </a>
                ) : (
                  <figure class="work__item">
                    <img
                      src={item.image}
                      alt={item.alt}
                      class="work__image"
                      loading="lazy"
                    />
                  </figure>
                )
              ) : item.href ? (
                <a href={item.href} class="work__item">
                  <video
                    class="work__video"
                    src={item.src}
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    aria-hidden="true"
                  ></video>
                  <span class="sr-only">{item.label}</span>
                </a>
              ) : (
                <figure class="work__item">
                  <video
                    class="work__video"
                    src={item.src}
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    aria-label={item.label}
                  ></video>
                </figure>
              )
            ))}
          </div>

          <div class="work__group" aria-hidden="true">
            {row.items.map((item) => (
              row.mediaType === 'image' ? (
                item.href ? (
                  <a href={item.href} class="work__item" tabIndex="-1">
                    <img
                      src={item.image}
                      alt=""
                      class="work__image"
                      loading="lazy"
                    />
                  </a>
                ) : (
                  <figure class="work__item">
                    <img
                      src={item.image}
                      alt=""
                      class="work__image"
                      loading="lazy"
                    />
                  </figure>
                )
              ) : item.href ? (
                <a href={item.href} class="work__item" tabIndex="-1">
                  <video
                    class="work__video"
                    src={item.src}
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    aria-hidden="true"
                  ></video>
                </a>
              ) : (
                <figure class="work__item">
                  <video
                    class="work__video"
                    src={item.src}
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    aria-hidden="true"
                  ></video>
                </figure>
              )
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</Section>

<script>
  const WORK_MARQUEE_BASE_DURATION_SECONDS = 40;

  const getWorkMarqueeMeasurements = (marquee) => {
    const track = marquee.querySelector('.work__track');
    const group = marquee.querySelector('.work__group');

    if (!track || !group) {
      return null;
    }

    const gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap || '0');
    const groupWidth = group.getBoundingClientRect().width;

    return {
      groupWidth,
      shift: groupWidth + gap,
    };
  };

  const updateWorkMarquees = () => {
    const marquees = Array.from(document.querySelectorAll('.work__marquee'));

    if (!marquees.length) {
      return;
    }

    const referenceMeasurements = getWorkMarqueeMeasurements(marquees[0]);

    if (!referenceMeasurements || referenceMeasurements.shift <= 0) {
      return;
    }

    const pixelsPerSecond =
      referenceMeasurements.shift / WORK_MARQUEE_BASE_DURATION_SECONDS;

    for (const marquee of marquees) {
      const measurements = getWorkMarqueeMeasurements(marquee);

      if (!measurements || measurements.shift <= 0) {
        continue;
      }

      marquee.style.setProperty(
        '--work-marquee-duration',
        `${measurements.shift / pixelsPerSecond}s`,
      );

      if (!marquee.classList.contains('work__marquee--reverse')) {
        continue;
      }

      const alignRight = marquee.getBoundingClientRect().width - measurements.groupWidth;

      marquee.style.setProperty(
        '--work-row-reverse-start',
        `${alignRight - measurements.shift}px`,
      );
      marquee.style.setProperty('--work-row-reverse-end', `${alignRight}px`);
    }
  };

  updateWorkMarquees();

  const workResizeObserver = new ResizeObserver(() => {
    updateWorkMarquees();
  });

  for (const marquee of document.querySelectorAll('.work__marquee')) {
    workResizeObserver.observe(marquee);

    const group = marquee.querySelector('.work__group');

    if (group) {
      workResizeObserver.observe(group);
    }
  }

  window.addEventListener('load', updateWorkMarquees, { once: true });
</script>
