---
const {
  href = '#',
  variant = 'primary',
  class: className = '',
  target,
  rel,
} = Astro.props;

const computedRel = rel ?? (target === '_blank' ? 'noreferrer' : undefined);
---

<a
  href={href}
  target={target}
  rel={computedRel}
  class={`button button--${variant} ${className}`.trim()}
>
  <slot />
</a>
