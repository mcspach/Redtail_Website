---
const {
  src,
  alt,
  caption = '',
  class: className = '',
} = Astro.props;

const captionText = caption?.trim();
---

<figure class={`case-study-wide-image ${className}`.trim()}>
  <img src={src} alt={alt} class="case-study-wide-image__image" loading="lazy" />
  {captionText && <figcaption class="case-study-wide-image__caption">{captionText}</figcaption>}
</figure>
