---
const {
  src = '',
  embedUrl = '',
  title = 'Case study video',
  poster = '',
  caption = '',
  autoplay = false,
  loop = false,
  muted = false,
  controls = true,
  class: className = '',
} = Astro.props;
---

<figure class={`case-study-wide-video ${className}`.trim()}>
  {embedUrl ? (
    <div class="case-study-wide-video__frame">
      <iframe
        src={embedUrl}
        title={title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
  ) : (
    <video
      class="case-study-wide-video__player"
      src={src}
      poster={poster || undefined}
      autoplay={autoplay}
      loop={loop}
      muted={muted}
      controls={controls}
      playsinline
      preload="metadata"
    >
      Your browser does not support the video tag.
    </video>
  )}
  {caption && <figcaption class="case-study-wide-video__caption">{caption}</figcaption>}
</figure>
