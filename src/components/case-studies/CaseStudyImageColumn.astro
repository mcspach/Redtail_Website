---
const {
  src,
  alt,
  caption = '',
  class: className = '',
} = Astro.props;

const captionText = caption?.trim();
---

<figure class={`case-study-image-column ${className}`.trim()}>
  <img src={src} alt={alt} class="case-study-image-column__image" loading="lazy" />
  {captionText && <figcaption class="case-study-image-column__caption">{captionText}</figcaption>}
</figure>
